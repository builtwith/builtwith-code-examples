BUILTWITH_API_KEY=your-api-key-here

# Primary technology to search for.
TECH=Google-Analytics

# Additional required technologies. Use comma-separated values for more than one, max 16.
OTHERTECHS=Meta-Pixel

# Optional max domains to print from paginated results.
MAX_DOMAINS=100

# Optional filters.
# COUNTRY=US
# SINCE=30 Days Ago
