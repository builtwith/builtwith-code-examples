BUILTWITH_API_KEY=your-api-key-here

# Technology to search (use dashes for spaces, e.g. "Google-Analytics")
TECH=Shopify

# Optional comma-separated technologies that each result must also use (max 16)
# OTHERTECHS=Google-Analytics,Meta-Pixel

# How many domains to fetch and enrich (default: 50)
MAX_DOMAINS=50

# Output CSV filename (default: <tech>-enriched.csv)
# OUTPUT_FILE=shopify-enriched.csv

# Filter: ISO 3166-1 alpha-2 country code(s), comma-separated. Use UK not GB.
# COUNTRY=US,CA

# Filter: only sites detected since this date or relative time
# SINCE=2024-01-01

# Numeric Lists API filters use number|operator. Operators: EQ, LT, LTE, GT, GTE.
# SPEND=100|GT
# REVENUE=100000|GT
# EMPLOYEES=50|GTE
# Other supported filters: SKU, FOLLOWERS, SITEMAP, PAGERANK, BWRANK, TRANCO, MAJESTIC, BWS, ECAT, AIM, AIO, AIR, AIV

# Domain API: keep only currently live technologies (default: true)
LIVEONLY=true

# Seconds to wait between Domain API calls to avoid rate limiting (default: 0.5)
ENRICH_DELAY=0.5
