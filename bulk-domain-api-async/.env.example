# BuiltWith API Key - get yours at https://api.builtwith.com
BUILTWITH_API_KEY=your-api-key-here

# ── Input ─────────────────────────────────────────────────────────────────────

# Path to a plain-text file with one domain per line
# INPUT_FILE=domains.txt

# Alternatively, a comma-separated list of domains
# DOMAINS=shopify.com,stripe.com,vercel.com

# ── Output ────────────────────────────────────────────────────────────────────

# Where to write the JSON results (default: bulk-results.json)
OUTPUT_FILE=bulk-results.json

# Where to save the job ID for resumption (default: bulk-job-id.txt)
JOB_ID_FILE=bulk-job-id.txt

# ── Resume ────────────────────────────────────────────────────────────────────

# Set this to skip submission and poll an existing job directly
# JOB_ID=abc123

# ── Poll ──────────────────────────────────────────────────────────────────────

# How often to check job status, in milliseconds (default: 10000)
POLL_INTERVAL=10000

# ── Domain API options ────────────────────────────────────────────────────────
LIVEONLY=false
NOMETA=false
NOPII=false
