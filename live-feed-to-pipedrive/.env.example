# BuiltWith API Key - get yours at https://api.builtwith.com
BUILTWITH_API_KEY=your-api-key-here

# Comma-separated list of channels to subscribe to
# Options: technology names (Shopify, WordPress), or rule channels (new, new-historical, premium)
BUILTWITH_CHANNELS=new,Shopify

# Domain API enrichment options
DOMAIN_API_LIVEONLY=true
DOMAIN_API_NOPII=false
DOMAIN_API_NOMETA=false
DOMAIN_API_NOATTR=true

# Pipedrive personal API token
# Find yours at https://app.pipedrive.com/settings/api
PIPEDRIVE_API_TOKEN=your-pipedrive-api-token-here

# Organization behavior
PIPEDRIVE_UPSERT_BY_NAME=true
PIPEDRIVE_ADD_NOTE=true
