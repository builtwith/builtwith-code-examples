BUILTWITH_API_KEY=your-api-key-here

# Keyword to search for
KEYWORD=perfume

# Minimum monthly spend in USD (default: 1000)
MIN_SPEND=1000

# Maximum number of sites to fetch from keyword search (default: 20)
MAX_RESULTS=20

# Seconds to wait between Domain API calls to avoid rate limiting (default: 0.5)
ENRICH_DELAY=0.5
