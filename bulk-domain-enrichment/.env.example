# BuiltWith API Key - get yours at https://api.builtwith.com
BUILTWITH_API_KEY=your-api-key-here

# Path to the input CSV file
INPUT_FILE=sample-domains.csv

# Name of the column containing domain names (default: domain)
DOMAIN_COLUMN=domain

# Enrichment mode: "free" (quick, low-cost) or "full" (Domain API, full tech stack)
API_MODE=free

# Output CSV path (default: <input-file>-enriched.csv)
# OUTPUT_FILE=sample-domains-enriched.csv

# Domain API: keep only currently live technologies — applies in "full" mode only
LIVEONLY=true

# Seconds to wait between API calls (default: 0.5)
ENRICH_DELAY=0.5
