# BuiltWith API Key - get yours at https://api.builtwith.com
BUILTWITH_API_KEY=your-api-key-here

# Technology to search for (use dashes for spaces, e.g. AB-Tasty)
TECH=Shopify

# Optional comma-separated technologies that each result must also use (max 16)
# OTHERTECHS=Google-Analytics,Meta-Pixel

# Include meta data (names, titles, social links, addresses, emails, phone numbers, traffic ranks)
# META=yes

# Filter by country TLD/address (ISO 3166-1 alpha-2, comma-separated, e.g. AU,NZ — use UK not GB)
# COUNTRY=us

# Only return sites live since a date or relative time (e.g. 2024-01-20, "30 Days Ago", "Last January")
# SINCE=30 Days Ago

# Numeric filters use number|operator. Operators: EQ, LT, LTE, GT, GTE. If omitted, GTE is used.
# Monthly technology spend
# SPEND=100|GT
# Estimated ecommerce sales revenue
# REVENUE=100000|GT
# Product count
# SKU=1000|GTE
# Employee count
# EMPLOYEES=50|GTE
# Other supported attribute filters: FOLLOWERS, SITEMAP, PAGERANK, BWRANK, TRANCO, MAJESTIC, BWS, ECAT, AIM, AIO, AIR, AIV

# Set to "yes" to include historical (non-live) sites — cannot be used with SINCE
# ALL=yes
